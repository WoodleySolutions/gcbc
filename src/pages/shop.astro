---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Store - Great Catholic Book Club"
  description="Shop official Great Catholic Book Club merchandise. Coffee mugs and tote bags for readers who believe every book is Catholic."
>
  <!-- Header Section -->
  <section class="bg-black-olive relative">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/SiteImages/A vast dimly lit library full of ancient interesting and colorful books.jpg');"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black-olive/80 via-black-olive/90 to-black-olive/95"></div>
    <div class="max-w-7xl mx-auto px-4 py-16 relative z-10">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-champaign-100 mb-8 font-headline drop-shadow-lg">
          GCBC Store
        </h1>
        <p class="text-xl text-champaign-200">
          Support the club and show your love for good literature
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Product: The Protoevangelium Collection -->
  <section class="py-16 bg-midnight-blue border-b border-champaign-700/20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <span class="inline-block bg-flame-500 text-midnight-blue text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">New Release</span>
        <h2 class="text-3xl font-bold text-champaign-100 font-headline mb-2">The Protoevangelium Collection</h2>
        <p class="text-champaign-300">Our first book — and we're proud of it.</p>
      </div>

      <div class="bg-black-olive border border-champaign-700/30 rounded-xl overflow-hidden shadow-2xl">
        <div class="grid md:grid-cols-2 gap-0">

          <!-- Cover Art -->
          <div class="bg-midnight-blue flex items-center justify-center p-8 min-h-64">
            <img
              src="/images/products/protoevangelium-collection-cover.png"
              alt="The Protoevangelium Collection"
              class="max-h-80 object-contain shadow-2xl rounded"
            />
          </div>

          <!-- Info -->
          <div class="p-10 flex flex-col justify-center">
            <p class="text-champaign-200 leading-relaxed mb-4">
              Eleven study guides for eleven beloved books — Dune, Ender's Game, Pride and Prejudice, Jurassic Park, and more — read through the lens of the Catholic intellectual tradition.
            </p>
            <p class="text-champaign-300 text-sm mb-6 leading-relaxed">
              This isn't a theology lecture. It's what happens when two converts who fell in love with these stories before they fell in love with the Church go back and discover what was already there.
            </p>

            <div class="space-y-3 mb-8">
              <div class="flex items-center justify-between text-sm border-b border-champaign-700/20 pb-2">
                <span class="text-champaign-300">PDF Download</span>
                <span class="text-champaign-100 font-bold">$14.99</span>
              </div>
              <div class="flex items-center justify-between text-sm border-b border-champaign-700/20 pb-2">
                <span class="text-champaign-300">Ebook (Kindle) <span class="text-flame-400 text-xs">· Free on Kindle Unlimited</span></span>
                <span class="text-champaign-100 font-bold">$9.99</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-champaign-300">Paperback</span>
                <span class="text-champaign-100 font-bold">$18.99</span>
              </div>
            </div>

            <a
              href="/shop/protoevangelium-collection"
              class="block w-full bg-flame-500 hover:bg-flame-600 text-midnight-blue text-center px-8 py-4 rounded-lg text-lg font-bold transition-colors shadow-md font-headline mb-3"
            >
              View & Purchase
            </a>
            <p class="text-champaign-400 text-xs text-center">PDF via Gumroad · Ebook &amp; Paperback via Amazon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section class="py-16 bg-black-olive">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-champaign-100 font-headline">Merchandise</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Coffee Mug -->
        <article class="bg-black-olive border border-champaign-700/30 rounded-lg overflow-hidden shadow-xl">
          <div class="aspect-square overflow-hidden bg-white">
            <img
              src="/images/products/mug-main.png"
              alt="Great Catholic Book Club Coffee Mug"
              class="w-full h-full object-contain hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-8">
            <h2 class="text-2xl font-bold text-champaign-100 mb-2 font-headline">
              Great Catholic Book Club Coffee Mug
            </h2>
            <p class="text-3xl font-bold text-champaign-100 mb-4">$15</p>
            <p class="text-champaign-300 text-sm mb-6">Free shipping included</p>

            <div class="mb-6">
              <p class="text-champaign-200 mb-4 leading-relaxed">
                Start your reading session with a warm cup of coffee in the official Great Catholic Book Club mug. Featuring our "Every Book is Catholic" logo, this 15oz ceramic mug is perfect for those quiet mornings with Scripture, contemplative afternoons with the month's selection, or late-night discussions with fellow readers.
              </p>
              <p class="text-champaign-200 mb-4 leading-relaxed">
                Whether you're savoring your favorite blend while diving into Tolkien or warming up with tea during your Lenten reading, this mug is a daily reminder that all good literature can lead us closer to Christ.
              </p>
            </div>

            <details class="mb-6">
              <summary class="text-champaign-100 font-semibold cursor-pointer hover:text-champaign-200 transition-colors mb-2">
                Product Features
              </summary>
              <ul class="text-champaign-300 text-sm space-y-1 ml-4 mt-2">
                <li>• 15oz capacity - perfect for coffee, tea, or hot chocolate</li>
                <li>• Glossy ceramic finish with vibrant, crisp printing</li>
                <li>• Microwave and dishwasher safe</li>
                <li>• Durable white ceramic construction</li>
                <li>• Features the Great Catholic Book Club logo</li>
              </ul>
            </details>

            <details class="mb-6">
              <summary class="text-champaign-100 font-semibold cursor-pointer hover:text-champaign-200 transition-colors mb-2">
                Care Instructions
              </summary>
              <p class="text-champaign-300 text-sm ml-4 mt-2">
                Clean in dishwasher or wash by hand with warm water and dish soap.
              </p>
            </details>

            <a
              href="https://square.link/u/HGnAzoFF"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full bg-rust-800 text-champaign-100 text-center px-8 py-4 rounded-lg text-lg font-semibold hover:bg-rust-900 transition-colors shadow-md"
            >
              Buy Now
            </a>
          </div>
        </article>

        <!-- Tote Bag -->
        <article class="bg-black-olive border border-champaign-700/30 rounded-lg overflow-hidden shadow-xl">
          <div class="aspect-square overflow-hidden bg-white">
            <img
              src="/images/products/tote-front.png"
              alt="GCBC Reader's Tote Bag"
              class="w-full h-full object-contain hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-8">
            <h2 class="text-2xl font-bold text-champaign-100 mb-2 font-headline">
              GCBC Reader's Tote Bag
            </h2>
            <p class="text-3xl font-bold text-champaign-100 mb-4">$25</p>
            <p class="text-champaign-300 text-sm mb-6">Free shipping included</p>

            <div class="mb-6">
              <p class="text-champaign-200 mb-4 leading-relaxed">
                Carry your books, journals, and reading essentials in style with the Great Catholic Book Club tote bag. Built for readers who take their books seriously, this spacious 18" x 18" tote is perfect for hauling your monthly selection, prayer books, notebooks, and everything else you need for book club meetings or personal reading time.
              </p>
              <p class="text-champaign-200 mb-4 leading-relaxed">
                Whether you're headed to Mass with your missal, the library with your stack of holds, or a coffee shop for quiet reading, this durable tote proclaims what we believe: Every Book is Catholic.
              </p>
            </div>

            <details class="mb-6">
              <summary class="text-champaign-100 font-semibold cursor-pointer hover:text-champaign-200 transition-colors mb-2">
                Product Features
              </summary>
              <ul class="text-champaign-300 text-sm space-y-1 ml-4 mt-2">
                <li>• Generous 18" x 18" size - fits multiple books with room to spare</li>
                <li>• Durable 100% polyester construction</li>
                <li>• Reinforced stitching on handles for heavy loads</li>
                <li>• Boxed corners for extra capacity and structure</li>
                <li>• Features the Great Catholic Book Club logo</li>
              </ul>
            </details>

            <details class="mb-6">
              <summary class="text-champaign-100 font-semibold cursor-pointer hover:text-champaign-200 transition-colors mb-2">
                Care Instructions
              </summary>
              <p class="text-champaign-300 text-sm ml-4 mt-2">
                Remove all items before cleaning. Pretreat visible stains with stain remover. Mix warm water with laundry detergent and clean with a soft cloth or bristle brush. Air dry completely.
              </p>
            </details>

            <a
              href="https://square.link/u/chgdycJa"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full bg-rust-800 text-champaign-100 text-center px-8 py-4 rounded-lg text-lg font-semibold hover:bg-rust-900 transition-colors shadow-md"
            >
              Buy Now
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-16 bg-rust-800">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-champaign-100 mb-4 font-headline">Join the Conversation</h2>
      <p class="text-champaign-200 mb-8 text-lg leading-relaxed">
        Merchandise purchases help support the club, but joining our reading community is always free. Check out our current book list and join the discussion!
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/books" class="inline-block bg-champaign-100 text-rust-800 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-champaign-200 transition-colors shadow-md">
          View Reading List
        </a>
        <a href="/join" class="inline-block bg-rust-600 text-champaign-100 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-rust-700 transition-colors shadow-md">
          Join Book Club
        </a>
      </div>
    </div>
  </section>

  <!-- Shipping & Returns Info -->
  <section class="py-12 bg-black-olive border-t border-champaign-700/30">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <h3 class="text-lg font-bold text-champaign-100 mb-2">Free Shipping</h3>
          <p class="text-champaign-300 text-sm">
            All prices include free domestic shipping. Orders typically ship within 3-5 business days.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-champaign-100 mb-2">Secure Checkout</h3>
          <p class="text-champaign-300 text-sm">
            Powered by Square. Your payment information is secure and encrypted.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-champaign-100 mb-2">Questions?</h3>
          <p class="text-champaign-300 text-sm">
            Email us at <a href="mailto:woodleys@greatcatholicbookclub.com" class="text-rust-400 hover:text-rust-300">woodleys@greatcatholicbookclub.com</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
